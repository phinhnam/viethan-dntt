# Sao chép file này thành .env rồi chỉnh theo môi trường của bạn.
# File .env KHÔNG được commit (đã có trong .gitignore).

HOST=127.0.0.1
PORT=5000
DEBUG=1

# Khóa ký cookie phiên đăng nhập - BẮT BUỘC đổi khi chạy thật
SECRET_KEY=doi-khoa-nay-truoc-khi-chay-that

# PostgreSQL đã dựng sẵn - điền thông tin kết nối thật vào đây
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/viethan_dntt
# Mặc định (không khai báo) dùng SQLite để chạy thử ngay: sqlite:///./dev.db
DATABASE_URL=sqlite:///./dev.db

# Thư mục lưu file chứng từ upload
UPLOAD_DIR=./uploads
